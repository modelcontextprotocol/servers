# Local NPM configuration for Sequential Thinking MCP Server
# Prevents NPM from auto-updating dependencies
# This ensures the local build remains stable until PR is merged

# Copy this file to: submodules/mcp-servers/src/sequentialthinking/.npmrc
# Command: cp .local-dev/mcp-servers/sequentialthinking/.npmrc submodules/mcp-servers/src/sequentialthinking/

# Disable automatic package updates
save-exact=true

# Prevent npm from modifying package-lock.json
package-lock=false

# Use local cache only (don't fetch from registry)
prefer-offline=true

# Prevent automatic dependency updates
save-prefix=""

