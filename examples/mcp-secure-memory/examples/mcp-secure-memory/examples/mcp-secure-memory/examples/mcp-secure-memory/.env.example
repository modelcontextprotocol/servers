# Synapse Layer MCP Secure Memory — Environment Variables
# ========================================================

# ID único do agente (pode mudar para cada cliente)
SYNAPSE_AGENT_ID=mcp-secure-memory

# Nível de privacidade diferencial (quanto menor, mais privacidade)
SYNAPSE_PRIVACY_EPSILON=0.5

# Nível de log (INFO, DEBUG, WARNING)
LOG_LEVEL=INFO
